# -----------------------------------------------
# Application Settings
# -----------------------------------------------
APP_NAME="HRMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# -----------------------------------------------
# Security
# -----------------------------------------------
BCRYPT_ROUNDS=12

# -----------------------------------------------
# Logging
# -----------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------
# Database (MySQL)
# -----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hrms
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------
# Session & Cache
# -----------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database

# -----------------------------------------------
# Queue
# -----------------------------------------------
QUEUE_CONNECTION=database

# -----------------------------------------------
# Filesystem
# -----------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# -----------------------------------------------
# Mail (switch MAIL_MAILER to "smtp" for real emails)
# -----------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------
# Redis (optional)
# -----------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------
# AWS (optional - for S3 file storage)
# -----------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------
# Vite (Frontend)
# -----------------------------------------------
VITE_APP_NAME="${APP_NAME}"
